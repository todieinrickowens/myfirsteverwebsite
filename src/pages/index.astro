const tools = [
  {
    title: 'УШМ 21V',
    image: '/products/angle-grinder.png',
    price: '25 600 ₸',
    status: 'В наличии',
    specs: ['100/125 мм', '0-9750 об/мин', '2 АКБ 3.0Ah + зарядка'],
  },
  {
    title: 'Перфоратор 21V',
    image: '/products/rotary-hammer.png',
    price: '31 000 ₸',
    status: 'В наличии',
    specs: ['Бур до 22 мм', '0-4500 ipm', '2 АКБ 3.0Ah + зарядка'],
  },
  {
    title: 'Дисковая пила 21V',
    image: '/products/circular-saw.png',
    price: '29 600 ₸',
    status: 'В наличии',
    specs: ['Диск до 150 мм', 'Глубина реза до 56 мм', '0-7000 об/мин'],
  },
  {
    title: 'Цепная пила 8″',
    image: '/products/chainsaw.png',
    price: '24 400 ₸',
    status: 'В наличии',
    specs: ['До 5800 об/мин', 'До 1800 Вт', '21V Li-ion'],
  },
  {
    title: 'Сабельная пила 21V',
    image: '/products/reciprocating-saw.png',
    price: '25 800 ₸',
    status: 'В наличии',
    specs: ['Ход 10 мм', '0-1620 spm', '2 пилки в комплекте'],
  },
  {
    title: 'Секатор 21V',
    image: '/products/pruner.png',
    price: '19 500 ₸',
    status: 'В наличии',
    specs: ['25/28/32/40 мм', 'Бесщеточный мотор', 'АКБ 1.5/2.0Ah'],
  },
  {
    title: 'Труборез 21V',
    image: '/products/pipe-cutter.png',
    price: '20 800 ₸',
    status: 'В наличии',
    specs: ['Рез до 30 мм', 'Бесщеточный мотор', 'АКБ 1.5/2.0Ah'],
  },
];

const priceRows = [
  ['Комплект 2-в-1: дрель + УШМ 100 мм', '2 АКБ 3.0Ah, зарядка, кейс', '31 000 ₸', 'Проверяем перед КП'],
  ['Комплект 2-в-1: дрель + УШМ 125 мм', '2 АКБ 3.0Ah, зарядка, кейс', '31 500 ₸', 'Проверяем перед КП'],
  ['Комплект 3-в-1: дрель + УШМ + перфоратор', 'УШМ 100 мм, 2 АКБ 3.0Ah', '49 300 ₸', 'Проверяем перед КП'],
  ['Комплект 3-в-1: гайковерт + УШМ + перфоратор', 'УШМ 100 мм, 2 АКБ 3.0Ah', '53 300 ₸', 'Проверяем перед КП'],
  ['Комплект 4-в-1', 'Дрель, гайковерт, УШМ, перфоратор', '60 100 ₸', 'Популярно для бригад'],
  ['Комплект 5-в-1', 'Плюс дисковая пила', '76 100 ₸', 'Проверяем перед КП'],
  ['Комплект 7-в-1', '7 инструментов, 4 АКБ, 2 зарядки', '108 400 ₸', 'Под расширенную закупку'],
  ['УШМ 21V', '100 мм, 2 АКБ 3.0Ah', '25 600 ₸', 'Проверяем перед КП'],
  ['Перфоратор 21V', '22 мм, 2 АКБ 3.0Ah', '31 000 ₸', 'Проверяем перед КП'],
  ['Дисковая пила 21V', '150 мм, 2 АКБ 3.0Ah', '29 600 ₸', 'Проверяем перед КП'],
  ['Цепная пила 8″', '21V, 2 АКБ', '24 400 ₸', 'Проверяем перед КП'],
  ['Сабельная пила 21V', '2 АКБ, 2 пилки', '25 800 ₸', 'Проверяем перед КП'],
  ['Секатор 21V', 'минимальная комплектация', '19 500 ₸', 'Проверяем перед КП'],
  ['Труборез 21V', 'рез до 30 мм', '20 800 ₸', 'Проверяем перед КП'],
];

const compareRows = [
  ['2-в-1', 'Мастер, ремонт, базовый набор', 'Дрель + УШМ', 'от 31 000 ₸', 'Минимальный вход в линейку'],
  ['4-в-1', 'Монтажная бригада', 'Дрель + гайковерт + УШМ + перфоратор', 'от 60 100 ₸', 'Закрывает основные задачи на объекте'],
  ['7-в-1', 'Расширенная закупка', '7 инструментов + 4 АКБ + 2 зарядки', 'от 108 400 ₸', 'Когда нужен один большой комплект'],
];

const trustItems = [
  { title: 'Компания с 2010 года', text: 'Продажи ведет команда Агромонтаж Групп. Адрес и контакты открыты.' },
  { title: 'КП под вашу задачу', text: 'Подберем комплект под вид работ, количество людей и бюджет.' },
  { title: 'Гарантия и сервис', text: 'Условия гарантии и сервиса фиксируем в КП по конкретной модели.' },
  { title: 'Астана и регионы', text: 'Самовывоз из Астаны или доставка по согласованию с менеджером.' },
];

const audienceCards = [
  {
    title: 'Бригаде на объект',
    text: 'Нужны дрель, УШМ, гайковерт и перфоратор без долгого подбора. Обычно смотрят 3-в-1, 4-в-1 и 5-в-1.',
  },
  {
    title: 'Закупщику и снабженцу',
    text: 'Нужны цена за 1 шт, наличие, комплектация и КП. По партии считаем отдельно.',
  },
  {
    title: 'Мастеру или сервиснику',
    text: 'Нужна одна понятная позиция: УШМ, перфоратор, пила или дрель. Подскажем, что подойдет под задачу.',
  },
  {
    title: 'Хозяйству или участку',
    text: 'Пилы, секаторы и труборезы для ремонта, сада и текущего обслуживания без привязки к розетке.',
  },
];

const conditions = [
  ['Наличие', 'Проверяем по конкретной модели в день обращения. Если позиции нет, сразу называем срок поставки.'],
  ['Доставка', 'По Астане и регионам Казахстана условия считаются отдельно. Можно обсудить самовывоз.'],
  ['Гарантия', 'Срок и условия гарантии указываем в КП или счете по выбранной модели и комплектации.'],
  ['Оплата', 'Для организаций готовим КП и счет. Способ оплаты уточняет менеджер при оформлении.'],
  ['Партия', 'Для закупки от нескольких единиц считаем цену партии и комплектацию отдельно.'],
  ['АКБ', 'В карточках указана базовая комплектация. Варианты 3.0Ah, 4.0Ah и другие АКБ уточняются перед счетом.'],
];

const faqItems = [
  ['Можно ли купить один инструмент, а не набор?', 'Да. УШМ, перфоратор, пилы, секатор и труборез можно запросить отдельно.'],
  ['Что входит в цену?', 'В прайсе указана базовая комплектация. Для части товаров это 2 АКБ и зарядка. Точный состав подтверждаем перед КП.'],
  ['Есть ли товар в наличии?', 'Наличие проверяем по SKU в день обращения. Если нужной модели нет, менеджер назовет ближайший срок поставки.'],
  ['Можно ли получить КП для закупки?', 'Да. Оставьте заявку через форму или WhatsApp: укажите модель, количество и город поставки.'],
  ['Что с гарантией?', 'Гарантийные условия фиксируются в КП или счете по конкретной модели. По сервису можно обратиться через отдел продаж.'],
  ['Можно ли оплатить онлайн?', 'Сейчас заказ оформляется через менеджера. Если нужна онлайн-оплата или счет для организации, напишите об этом в заявке.'],
];

const quoteMail = `mailto:${email}?subject=${encodeURIComponent('Заявка на КП HammerPro')}&body=${encodeURIComponent('Здравствуйте! Нужен КП на HammerPro.\nМодель/набор:\nКоличество:\nГород поставки:\nТелефон:')}`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'HammerPro 21V',
  itemListElement: [...sets, ...tools].map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Product',
      name: item.title,
      description: item.subtitle || item.specs.join(', '),
      image: `${pageUrl}${item.image.replace(/^\//, '')}`,
      brand: { '@type': 'Brand', name: 'HammerPro' },
      offers: {
        '@type': 'Offer',
        priceCurrency: 'KZT',
        price: item.price.replace(/\D/g, ''),
        availability: 'https://schema.org/LimitedAvailability',
        url: pageUrl,
      },
    },
  })),
};

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'HammerPro',
  url: pageUrl,
  image: `${pageUrl}products/set-7.png`,
  email,
  telephone: phones.map((phone) => phone.label),
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'KZ',
    addressLocality: 'Астана',
    streetAddress: 'Шоссе Коргалжын 19т, офис 407 Б',
  },
  openingHours: 'Mo-Fr 09:00-18:00',
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HammerPro - аккумуляторный инструмент 21V в Астане</title>
    <meta
      name="description"
      content="HammerPro: аккумуляторные наборы и инструмент 21V для монтажа, ремонта и хозяйства. Цены за 1 шт, подбор комплектации, КП и доставка по Казахстану."
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title" content="HammerPro - аккумуляторный инструмент 21V" />
    <meta property="og:description" content="Наборы 2-в-1, 4-в-1, 7-в-1 и отдельные позиции. Цены за 1 шт в тенге, КП по запросу." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={`${pageUrl}products/set-7.png`} />
    <script type="application/ld+json" set:html={JSON.stringify([businessSchema, productSchema])}></script>
  </head>
  <body>
    <header class="site-header">
      <a href="#top" class="logo" aria-label="HammerPro">
        <span class="logo-mark">HP</span>
        <span>
          <b>HammerPro</b>
          <small>Аккумуляторный инструмент 21V</small>
        </span>
      </a>

      <nav class="nav" aria-label="Навигация">
        <a href="#sets">Наборы</a>
        <a href="#tools">Инструмент</a>
        <a href="#prices">Цены</a>
        <a href="#quote">КП</a>
        <a href="#contacts">Контакты</a>
      </nav>

      <a class="header-phone" href={phones[0].href}>{phones[0].label}</a>
    </header>

    <main id="top">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">21V Li-ion / наборы / отдельный инструмент</p>
          <h1>Аккумуляторные наборы HammerPro для объекта, ремонта и хозяйства</h1>
          <p class="lead">
            Подбираем комплект под конкретную работу: монтаж, резка металла, бетон, дерево, сад или закупка для бригады.
            Сразу считаем цену за 1 шт, проверяем наличие и готовим КП.
          </p>

          <div class="hero-actions">
            <a class="btn primary" href="#quote">Получить КП</a>
            <a class="btn secondary" href={phones[0].wa}>Написать в WhatsApp</a>
          </div>

          <div class="hero-notes" aria-label="Ключевые преимущества">
            <div><b>21V</b><span>единая аккумуляторная линейка</span></div>
            <div><b>2-7</b><span>инструментов в готовых наборах</span></div>
            <div><b>₸/шт</b><span>цены указаны за одну позицию</span></div>
          </div>
        </div>

        <div class="hero-visual" aria-label="HammerPro 7-в-1">
          <div class="hero-visual-bg"></div>
          <img src="/products/set-7.png" alt="Комплект HammerPro 7-в-1" loading="eager" />
          <div class="hero-label">
            <span>Расширенный комплект</span>
            <strong>от 108 400 ₸ / шт</strong>
          </div>
        </div>
      </section>

      <section class="trust-bar section-tight" aria-label="Доверие и условия">
        {trustItems.map((item) => (
          <article>
            <b>{item.title}</b>
            <span>{item.text}</span>
          </article>
        ))}
      </section>

      <section class="section intro-strip">
        <div>
          <p class="eyebrow">Подбор комплектации</p>
          <h2>Не надо угадывать модель. Достаточно описать задачу</h2>
          <p>
            Мы разделили линейку по понятным сценариям: для бригады, закупки, сервиса и хозяйства.
            Так проще выбрать комплект и не переплачивать за лишние позиции.
          </p>
        </div>
        <div class="audience-grid">
          {audienceCards.map((item) => (
            <article>
              <b>{item.title}</b>
              <span>{item.text}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="section benefit-section">
        <div class="section-head centered">
          <p class="eyebrow">Почему комплект выгоднее</p>
          <h2>Одна 21V линейка — меньше лишних зарядок и проще закупка</h2>
          <p>
            Если на объекте несколько задач, комплект удобнее покупать и обслуживать: инструменты идут в одной системе,
            а менеджер сразу проверяет аккумуляторы, зарядки, диск 100/125 мм и доступность доп. АКБ.
          </p>
        </div>

        <div class="benefit-grid">
          <article>
            <b>Меньше подбора вручную</b>
            <span>Можно взять готовый 3-в-1, 4-в-1 или 7-в-1, а не собирать каждую позицию отдельно.</span>
          </article>
          <article>
            <b>Понятный бюджет</b>
            <span>На странице указаны цены за 1 шт. Для партии считаем отдельное предложение.</span>
          </article>
          <article>
            <b>Проще для бригады</b>
            <span>Один комплект закрывает сверление, резку, крепеж и часть сервисных задач на выезде.</span>
          </article>
        </div>
      </section>

      <section class="section" id="sets">
        <div class="section-head">
          <p class="eyebrow">Готовые наборы</p>
          <h2>Комплекты HammerPro 21V</h2>
          <p>Варианты от 2 до 7 инструментов. Подходят для ремонта, выездных работ и закупки на объект.</p>
        </div>

        <div class="product-grid">
          {sets.map((item) => (
            <article class:list={['product-card', { featured: item.featured }]}> 
              {item.featured && <span class="badge">Часто выбирают</span>}
              <div class="image-wrap">
                <img src={item.image} alt={item.title} loading="lazy" />
              </div>
              <div class="product-body">
                <p class="product-kicker">Набор 21V</p>
                <h3>{item.title}</h3>
                <p>{item.subtitle}</p>
                <div class="stock-pill">{item.status}</div>
                <div class="price"><span>от</span><strong>{item.price}</strong><small>за 1 шт</small></div>
                <ul>
                  {item.specs.map((spec) => <li>{spec}</li>)}
                </ul>
                <a class="mini-link" href="#quote">Запросить КП</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section compare-section">
        <div class="section-head">
          <p class="eyebrow">Сравнение</p>
          <h2>Какой комплект выбрать</h2>
          <p>Быстрое сравнение основных наборов, чтобы не листать все карточки вручную.</p>
        </div>

        <div class="price-table-wrap">
          <table class="price-table compare-table">
            <thead>
              <tr>
                <th>Набор</th>
                <th>Кому подходит</th>
                <th>Что внутри</th>
                <th>Цена</th>
                <th>Комментарий</th>
              </tr>
            </thead>
            <tbody>
              {compareRows.map((row) => (
                <tr>
                  <td><b>{row[0]}</b></td>
                  <td>{row[1]}</td>
                  <td>{row[2]}</td>
                  <td><b>{row[3]}</b></td>
                  <td>{row[4]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="section dark" id="tools">
        <div class="section-head light">
          <p class="eyebrow">Отдельные позиции</p>
          <h2>Когда нужен один конкретный инструмент</h2>
          <p>Можно взять не набором, а одной позицией: для склада, ремонта или доукомплектации бригады.</p>
        </div>

        <div class="tool-grid">
          {tools.map((item) => (
            <article class="tool-card">
              <div class="tool-image"><img src={item.image} alt={item.title} loading="lazy" /></div>
              <div class="tool-info">
                <h3>{item.title}</h3>
                <div class="stock-pill dark-pill">{item.status}</div>
