    specs: ['Перфоратор до 1400 об/мин', 'Удар до 4500 ipm', 'Бур до 22 мм', '2 АКБ 3.0Ah + зарядка'],
  },
  {
    title: 'HammerPro 3-в-1 с гайковертом',
    subtitle: 'Гайковерт, УШМ и перфоратор',
