    featured: true,
  },
  {
    title: 'HammerPro 5-в-1',
    subtitle: 'Комплект с дисковой пилой',
    image: '/products/set-5.png',
    price: '76 100 ₸',
    status: 'В наличии',
    specs: ['Пила до 7000 об/мин', 'Диск до 150 мм', 'Рез до 56 мм', 'Для выездных работ'],
  },
  {
